generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  uid          String   @unique // Firebase UID
  name         String
  email        String   @unique
  phone        String?
  address      String?  @db.Text
  role         String   @default("user")
  authProvider String   @default("firebase") // firebase, email, etc.
  localPasswordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Category {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  icon String?

  subcategories SubCategory[]
  products      Product[]
  modelTests    ModelTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubCategory {
  id   String @id @default(cuid())
  name String
  slug String @unique

  parentCategory   Category @relation(fields: [parentCategoryId], references: [id])
  parentCategoryId String

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String  @id @default(cuid())
  title         String
  uniqueId      String  @unique
  coverImage    String
  description   String  @db.Text
  regularPrice  Float
  discountPrice Float?
  demoPdfUrl    String?

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  subcategory   SubCategory? @relation(fields: [subcategoryId], references: [id])
  subcategoryId String?

  tags Tag[]

  allChaptersPrice Float

  chapters Chapter[]
  orders   OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chapter {
  id     String @id @default(cuid())
  name   String
  pdfUrl String @db.Text
  price  Float
  order  Int    @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
}

model Order {
  id      String @id @default(cuid())
  orderId String @unique

  userId String
  user   User   @relation(fields: [userId], references: [uid])

  subtotal          Float
  serviceFee        Float     @default(0)
  totalAmount       Float
  status            String    @default("pending")
  fulfillmentMethod String    @default("digital")
  paymentMethod     String?
  transactionId     String?
  paymentStatus     String    @default("unpaid")
  paymentGateway    String?
  sslSessionKey     String?
  sslValId          String?
  paidAt            DateTime?
  currency          String    @default("BDT")
  gatewayResponse   Json?
  shippingAddress   String?   @db.Text
  customerName      String
  customerEmail     String
  customerPhone     String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  // Product-based item (optional — null for model test items)
  product      Product? @relation(fields: [productId], references: [id])
  productId    String?
  productTitle String

  // Model Test-based item (optional — null for product items)
  modelTest   ModelTest? @relation(fields: [modelTestId], references: [id])
  modelTestId String?

  isAllChapters Boolean @default(false)
  price         Float

  headerLeftText  String?
  headerRightText String?
  watermarkText   String?
  coverPageText   String?

  // Product chapters download
  downloadUrl     String? @db.Text

  // Model test item downloads
  questionsDownloadUrl  String? @db.Text
  solutionsDownloadUrl  String? @db.Text

  chaptersItem OrderChapter[]
  modelTestOrderItems OrderModelTestItem[]
}

model OrderChapter {
  id     String @id @default(cuid())
  name   String
  pdfUrl String @db.Text
  price  Float

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String
}

model ModelTest {
  id            String  @id @default(cuid())
  title         String
  uniqueId      String  @unique
  coverImage    String
  description   String  @db.Text
  regularPrice  Float
  discountPrice Float?
  demoPdfUrl    String?
  allItemsPrice Float

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  items  ModelTestItem[]
  orders OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModelTestItem {
  id              String @id @default(cuid())
  name            String
  questionsDocxUrl String @map("questionsZipUrl") @db.Text
  solutionPdfUrl  String @db.Text
  price           Float
  order           Int    @default(0)

  modelTest   ModelTest @relation(fields: [modelTestId], references: [id], onDelete: Cascade)
  modelTestId String

  orderItems OrderModelTestItem[]
}

model OrderModelTestItem {
  id    String @id @default(cuid())
  name  String
  questionsDocxUrl     String @map("questionsZipUrl") @db.Text
  solutionPdfUrl      String @db.Text
  price               Float

  // Generated files after purchase
  questionsDownloadUrl String? @db.Text
  solutionsDownloadUrl String? @db.Text

  orderItem      OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId    String

  modelTestItem   ModelTestItem? @relation(fields: [modelTestItemId], references: [id])
  modelTestItemId String?
}

model Settings {
  id          String   @id @default(cuid())
  bkashNumber String   @default("")
  nagadNumber String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
