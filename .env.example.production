# Docker Compose (production)
POSTGRES_DB=orbitacademy
POSTGRES_USER=orbitacademy
POSTGRES_PASSWORD=orbitacademy-strong-password

# Docker ports
POSTGRES_HOST_PORT=5433
POSTGRES_CONTAINER_PORT=5432
BACKEND_HOST_PORT=5000
BACKEND_CONTAINER_PORT=5000
FRONTEND_HOST_PORT=3001
FRONTEND_CONTAINER_PORT=3000

# Public domain URLs
FRONTEND_PUBLIC_URL=https://documents.orbitacademyonline.com
BACKEND_PUBLIC_URL=https://documents.orbitacademyonline.com
BACKEND_SERVER_URL=https://documents.orbitacademyonline.com

# CORS allowlist (comma-separated)
CORS_ORIGINS=https://documents.orbitacademyonline.com,https://www.documents.orbitacademyonline.com

# Public app URLs (frontend/runtime)
NEXT_PUBLIC_SITE_URL=https://documents.orbitacademyonline.com
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_AI_API_URL=/api

# Optional AI service endpoint (if you add AI routes/service later)
